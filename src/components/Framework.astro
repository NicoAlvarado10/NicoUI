---
const {image, alt, label, href} = Astro.props
---
<a href={href}>
    <article class="cursor-pointer py-8 px-28  m-auto flex flex-col gap-5 framework bg-slate-950 rounded-2xl">
        <img src={image} alt={alt} width="80" class="frameworks-img aspect-square">
        <span class="text-center text-gray-400">{label}</span>
    </article>
</a>

<style>
.framework{
    
    transition:all 0.3s;
}

.framework:hover span{
    text-decoration: underline;
}
.framework:hover{
    box-shadow: 5px 5px 5px #9aaecf;
}
</style>


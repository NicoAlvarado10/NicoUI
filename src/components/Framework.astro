---
const {image, alt, label} = Astro.props
---
<article class="py-8 px-28  m-auto flex flex-col gap-5 framework ">
    <img src={image} alt={alt} width="80" class="frameworks-img">
    <span class="text-center text-gray-400">{label}</span>
</article>

<style>
.framework{
    
    transition:all 0.3s;
}

.framework:hover span{
    text-decoration: underline;
}
.framework:hover{
    box-shadow: 5px 5px 10px #9ca3af;
}
</style>


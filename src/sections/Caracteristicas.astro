---

import { Copy, Layout, Palette } from "lucide-react";

---

<section class="py-24 px-8 max-w-7xl m-auto ">
    <h2 class="text-white text-center text-5xl">Caracteristicas</h2>
    <div class="grid grid-cols-3 items-center gap-8 pt-20">
        <article class="caracteristica-1 rounded-xl text-center py-8 px-8">
            <div class="flex m-auto w-14 bg-blue-500 p-3 rounded-full mb-2 transtion duration-150 hover:bg-blue-400 ">
                <Copy className="h-8 w-8 text-white"/>
            </div>
            <h3 class="text-white text-xl font-semibold mb-2 tracking-wide">Copiar y Pegar</h3>
            <p class="text-gray-400">Simplemente copia el código del componente y pégalo en tu proyecto
            </p>
        </article>
        <article class="caracteristica-2 text-center py-8 px-8 rounded-xl">
            <div class="flex m-auto w-14 bg-green-500 p-3 rounded-full mb-2 transtion duration-150 hover:bg-green-400">
                <Layout className="h-8 w-8 text-white" />
              </div>
              <h3 class="text-white  text-xl font-semibold mb-2 tracking-wide">Compatible</h3>
              <p class="text-gray-400 ">Componentes compatibles con React, Vue, Angular y otros frameworks populares</p>
        </article>
        <article class="caracteristica-3 text-center py-8 px-8 rounded-xl">
            <div class="flex m-auto w-14 bg-purple-500 p-3 rounded-full mb-2 transtion duration-150 hover:bg-purple-400">
                <Palette className="h-8 w-8 text-white" />
              </div>
              <h3 class="text-white text-xl font-semibold mb-2 tracking-wide">Personalizable</h3>
              <p class="text-gray-400">Fácil de adaptar a tu diseño y necesidades específicas</p>
        </article>
    </div>
    <div class="flex justify-center items-center mt-14">
        <span class="text-gray-400 transform italic text-lg underline">
            "Lo simple es la clave de la brillantez" Bruce Lee
        </span>
    </div>
</section>

<style>
  .caracteristica-1{
        box-shadow: 5px 5px 5px  #3b82f6;
        transition: 0.3s;
    }
    .caracteristica-1:hover{
        box-shadow: 5px 5px 10px #60a5fa; 
    }

    .caracteristica-2{
        box-shadow: 5px 5px 5px  #4ade80;
        transition: 0.3s;
    }
    .caracteristica-2:hover{
        box-shadow: 5px 5px 10px #22c55e  ; 
    }

    .caracteristica-3{
        box-shadow: 5px 5px 5px   #a855f7;
        transition: 0.3s;
    }
    .caracteristica-3:hover{
        box-shadow: 5px 5px 10px #c084fc ; 
    }
    
</style>